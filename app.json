{
  "expo": {
    "name": "Vaibes",
    "slug": "vibes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.vaibes.app",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vaibes.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/vaibe-chime.caf"
          ]
        }
      ],
      "expo-secure-store",
      "./plugins/with-podfile-fixes.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "242b435b-849a-44e8-9f32-364969589ddd"
      }
    },
    "owner": "agonzalez1704",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/242b435b-849a-44e8-9f32-364969589ddd"
    }
  }
}